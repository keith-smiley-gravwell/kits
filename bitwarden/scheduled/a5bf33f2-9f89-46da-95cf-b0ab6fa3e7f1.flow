{"id":"gravwell@0.0.1","nodes":{"3216":{"id":3216,"name":"HTTP","inputs":{"in":{"connections":[{"node":3225,"output":"out","data":{}}]}},"outputs":{"out":{"connections":[{"node":3219,"input":"in","data":{}}]}},"data":{"url":{"type":"Constant","value":"https://identity.bitwarden.com/connect/token"},"method":{"type":"Constant","value":"POST"},"body":{"type":"Variable","value":"BW_SECRET"},"maxsize":{"type":"Constant","value":67108864},"skipverify":{"type":"Constant","value":false},"headers":{"type":"Map","map":{"Content-Type":{"type":"Constant","value":"application/x-www-form-urlencoded"}}},"decodebody":{"type":"Constant","value":false},"__meta":{"nickname":"Bitwarden Auth","notes":null,"inputs":[],"values":{"url":{"type":{"kind":"string"},"value":"https://identity.bitwarden.com/connect/token"},"method":{"type":{"kind":"enum:string","values":["GET","POST","PUT","DELETE"]},"value":"POST"},"body":{"type":{"kind":"variable"},"value":"BW_SECRET"},"timeout":{"type":{"kind":"int"},"value":null},"maxsize":{"type":{"default":67108864,"kind":"int"},"value":67108864},"skipverify":{"type":{"kind":"boolean"},"value":false},"headers":{"Content-Type":{"type":{"kind":"string"},"value":"application/x-www-form-urlencoded"}},"decodebody":{"type":{"kind":"boolean"},"value":false}}},"__disabled":{"type":"Constant","value":false}},"position":[-1024,-480]},"3219":{"id":3219,"name":"Template","inputs":{"in":{"connections":[{"node":3216,"output":"out","data":{}}]}},"outputs":{"out":{"connections":[{"node":3265,"input":"in","data":{}}]}},"data":{"template":{"type":"Constant","value":"{{.response.access_token}}"},"name":{"type":"Constant","value":"token"},"__meta":{"nickname":"Set token variable","notes":null,"inputs":[],"values":{"template":{"type":{"kind":"string:longtext"},"value":"{{.response.access_token}}"},"name":{"type":{"default":"templateOutput","kind":"string"},"value":"token"}}},"__disabled":{"type":"Constant","value":false}},"position":[-784,-480]},"3224":{"id":3224,"name":"Ingest","inputs":{"in":{"connections":[{"node":3265,"output":"out","data":{}}]}},"outputs":{"out":{"connections":[]}},"data":{"tag":{"type":"Constant","value":"bitwarden"},"input":{"type":"Variable","value":"data"},"splitlines":{"type":"Constant","value":true},"extracttimestamp":{"type":"Constant","value":true},"__meta":{"nickname":null,"notes":null,"inputs":[],"values":{"tag":{"type":{"kind":"string"},"value":"bitwarden"},"input":{"type":{"kind":"variable"},"value":"data"},"splitlines":{"type":{"kind":"boolean"},"value":true},"extracttimestamp":{"type":{"kind":"boolean"},"value":true}}},"__disabled":{"type":"Constant","value":false}},"position":[-288,-480]},"3225":{"id":3225,"name":"Go","inputs":{"in":{"connections":[{"node":3266,"output":"out","data":{}}]}},"outputs":{"out":{"connections":[{"node":3216,"input":"in","data":{}}]}},"data":{"outputs":{"type":"Array","array_elements":[{"type":"Constant","value":"BW_SECRET"}]},"code":{"type":"Constant","value":"package main\r\n\r\nimport (\r\n\t\"gravwell\"\r\n)\r\n\r\nvar payload = gravwell.Payload\r\n\r\nfunc main() {\r\n    sec,err := gravwell.GetSecret(\"BW_SECRET\")\r\n    if err != nil {\r\n        panic(err)\r\n    }\r\n\r\n    payload.Set(\"BW_SECRET\",sec)\r\n    \r\n\treturn\r\n}"},"__meta":{"nickname":"Get Bitwarden Secret","notes":null,"inputs":[],"values":{"outputs":[{"type":{"kind":"string"},"value":"BW_SECRET"}],"code":{"type":{"default":"package main\n\nimport (\n\t\"gravwell\"\n)\n\n/* payload implements a Get and Set, like this interface: \ntype payload interface {\n\tGet(string) (interface{}, error)\n\tSet(string, interface{}) error\n}\n*/\n\nvar payload = gravwell.Payload\n\nfunc main() {\n\treturn\n}","kind":"string:code-go"},"value":"package main\r\n\r\nimport (\r\n\t\"gravwell\"\r\n)\r\n\r\nvar payload = gravwell.Payload\r\n\r\nfunc main() {\r\n    sec,err := gravwell.GetSecret(\"BW_SECRET\")\r\n    if err != nil {\r\n        panic(err)\r\n    }\r\n\r\n    payload.Set(\"BW_SECRET\",sec)\r\n    \r\n\treturn\r\n}"}}},"__disabled":{"type":"Constant","value":false}},"position":[-1312,-480]},"3265":{"id":3265,"name":"Go","inputs":{"in":{"connections":[{"node":3219,"output":"out","data":{}}]}},"outputs":{"out":{"connections":[{"node":3224,"input":"in","data":{}}]}},"data":{"outputs":{"type":"Array","array_elements":[{"type":"Constant","value":"data"}]},"code":{"type":"Constant","value":"package main\r\n\r\nimport (\r\n    \"gravwell\"\r\n    \"encoding/json\"\r\n    \"net/http\"\r\n    \"net/url\"\r\n    \"io\"\r\n    \"time\"\r\n    \"fmt\"\r\n)\r\n\r\ntype Response struct {\r\n    ContinuationToken string `json:\"continuationToken\"`\r\n    Data              []json.RawMessage //`json:\"data\"`\r\n    Object string `json:\"object\"`\r\n}\r\n\r\nvar payload = gravwell.Payload\r\n\r\nfunc main() {\r\n    // Grabbing all records from the last run until now\r\n    // using these should allow backfill of missed runs without double ingesting\r\n    start := gravwell.START.Add(time.Minute * time.Duration(-11))\r\n    end := gravwell.START.Add(time.Minute * time.Duration(-5))\r\n\r\n    params := url.Values{}\r\n    params.Set(\"start\", start.Format(time.RFC3339))\r\n    params.Set(\"end\", end.Format(time.RFC3339))\r\n\r\n    var continuation string\r\n    var data string\r\n    var endpoint string\r\n\r\n    // Set API endpoint\r\n    web, err := payload.Get(\"BITWARDEN_WEB\")\r\n    if err != nil {\r\n        panic(err)\r\n    }       \r\n\r\n    if web == \"api.bitwarden.com\" {\r\n        endpoint = web.(string)\r\n    } else {\r\n        endpoint = web.(string) + \"/api\"\r\n    }\r\n\r\n    for { // we loop forever until broken out but the `break` below\r\n        if continuation != \"\" {\r\n            params.Set(\"continuationToken\", continuation)\r\n        }\r\n\r\n        request, err := http.NewRequest(http.MethodGet, \"https://\" + endpoint + \"/public/events?\"+params.Encode(), nil)\r\n        if err != nil {\r\n            panic(err)\r\n        }\r\n\r\n        // Read in the token that was passed in\r\n        t, err := payload.Get(\"token\")\r\n        if err != nil {\r\n            panic(err)\r\n        }\r\n\r\n        token, ok := t.(string)\r\n        if !ok {\r\n            panic(\"token not a string\")\r\n        }\r\n        \r\n        request.Header.Set(\"Authorization\", fmt.Sprintf(\"Bearer %s\", token))\r\n        r, err := http.DefaultClient.Do(request)\r\n        if err != nil {\r\n            panic(err)\r\n        }\r\n\r\n        response, err := parse(r)\r\n        if err != nil {\r\n            panic(err)\r\n        }\r\n\r\n        for _, record := range response.Data {\r\n            data += string(record) + \"\\n\"\r\n        }\r\n\r\n        continuation = response.ContinuationToken\r\n        if response.ContinuationToken == \"\" {\r\n            break // this will break out as soon as there isn't any more records in the time range we are looking at\r\n        }\r\n    }\r\n    payload.Set(\"data\", data)\r\n    //println(string(data))\r\n    return\r\n}\r\n\r\n// parse out the body into a response\r\n// This closes the body\r\nfunc parse(response *http.Response) (*Response, error) {\r\n    body, err := io.ReadAll(response.Body)\r\n    response.Body.Close()\r\n    if err != nil {\r\n        return nil, err\r\n    }\r\n\r\n    var r Response\r\n    if err := json.Unmarshal(body, &r); err != nil {\r\n        return nil, err\r\n    }\r\n\r\n    return &r, nil\r\n}"},"__meta":{"nickname":"Pull event logs","notes":null,"inputs":[],"values":{"outputs":[{"type":{"kind":"string"},"value":"data"}],"code":{"type":{"default":"package main\n\nimport (\n\t\"gravwell\"\n)\n\n/* payload implements a Get and Set, like this interface: \ntype payload interface {\n\tGet(string) (interface{}, error)\n\tSet(string, interface{}) error\n}\n*/\n\nvar payload = gravwell.Payload\n\nfunc main() {\n\treturn\n}","kind":"string:code-go"},"value":"package main\r\n\r\nimport (\r\n    \"gravwell\"\r\n    \"encoding/json\"\r\n    \"net/http\"\r\n    \"net/url\"\r\n    \"io\"\r\n    \"time\"\r\n    \"fmt\"\r\n)\r\n\r\ntype Response struct {\r\n    ContinuationToken string `json:\"continuationToken\"`\r\n    Data              []json.RawMessage //`json:\"data\"`\r\n    Object string `json:\"object\"`\r\n}\r\n\r\nvar payload = gravwell.Payload\r\n\r\nfunc main() {\r\n    // Grabbing all records from the last run until now\r\n    // using these should allow backfill of missed runs without double ingesting\r\n    start := gravwell.START.Add(time.Minute * time.Duration(-11))\r\n    end := gravwell.START.Add(time.Minute * time.Duration(-5))\r\n\r\n    params := url.Values{}\r\n    params.Set(\"start\", start.Format(time.RFC3339))\r\n    params.Set(\"end\", end.Format(time.RFC3339))\r\n\r\n    var continuation string\r\n    var data string\r\n    var endpoint string\r\n\r\n    // Set API endpoint\r\n    web, err := payload.Get(\"BITWARDEN_WEB\")\r\n    if err != nil {\r\n        panic(err)\r\n    }       \r\n\r\n    if web == \"api.bitwarden.com\" {\r\n        endpoint = web.(string)\r\n    } else {\r\n        endpoint = web.(string) + \"/api\"\r\n    }\r\n\r\n    for { // we loop forever until broken out but the `break` below\r\n        if continuation != \"\" {\r\n            params.Set(\"continuationToken\", continuation)\r\n        }\r\n\r\n        request, err := http.NewRequest(http.MethodGet, \"https://\" + endpoint + \"/public/events?\"+params.Encode(), nil)\r\n        if err != nil {\r\n            panic(err)\r\n        }\r\n\r\n        // Read in the token that was passed in\r\n        t, err := payload.Get(\"token\")\r\n        if err != nil {\r\n            panic(err)\r\n        }\r\n\r\n        token, ok := t.(string)\r\n        if !ok {\r\n            panic(\"token not a string\")\r\n        }\r\n        \r\n        request.Header.Set(\"Authorization\", fmt.Sprintf(\"Bearer %s\", token))\r\n        r, err := http.DefaultClient.Do(request)\r\n        if err != nil {\r\n            panic(err)\r\n        }\r\n\r\n        response, err := parse(r)\r\n        if err != nil {\r\n            panic(err)\r\n        }\r\n\r\n        for _, record := range response.Data {\r\n            data += string(record) + \"\\n\"\r\n        }\r\n\r\n        continuation = response.ContinuationToken\r\n        if response.ContinuationToken == \"\" {\r\n            break // this will break out as soon as there isn't any more records in the time range we are looking at\r\n        }\r\n    }\r\n    payload.Set(\"data\", data)\r\n    //println(string(data))\r\n    return\r\n}\r\n\r\n// parse out the body into a response\r\n// This closes the body\r\nfunc parse(response *http.Response) (*Response, error) {\r\n    body, err := io.ReadAll(response.Body)\r\n    response.Body.Close()\r\n    if err != nil {\r\n        return nil, err\r\n    }\r\n\r\n    var r Response\r\n    if err := json.Unmarshal(body, &r); err != nil {\r\n        return nil, err\r\n    }\r\n\r\n    return &r, nil\r\n}"}}},"__disabled":{"type":"Constant","value":false}},"position":[-528,-480]},"3266":{"id":3266,"name":"MacroGet","inputs":{"in":{"connections":[]}},"outputs":{"out":{"connections":[{"node":3225,"input":"in","data":{}}]}},"data":{"macros":{"type":"Array","array_elements":[{"type":"Constant","value":"BITWARDEN_WEB"}]},"__meta":{"nickname":"Read BITWARDEN_WEB","notes":null,"inputs":[],"values":{"macros":[{"type":{"kind":"string"},"value":"BITWARDEN_WEB"}]}},"__disabled":{"type":"Constant","value":false}},"position":[-1568,-480]}}}